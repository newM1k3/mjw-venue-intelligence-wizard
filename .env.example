# mjw-venue-intelligence-wizard — environment variables
# Copy to `.env` and fill in. Use `netlify dev` so the serverless function runs.

# ── Client (VITE_*, inlined into the bundle — no secrets) ─────────────────────
# PocketBase backend base URL
VITE_POCKETBASE_URL=https://immersive-kit.pockethost.io
# Where the "Go to dashboard" button sends operators when onboarding finishes
VITE_DASHBOARD_URL=https://immersivekit.ca/dashboard

# ── Server (Netlify function only — NEVER prefix these with VITE_) ─────────────
# Anthropic API key used by netlify/functions/scrape-venue.mjs
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6
